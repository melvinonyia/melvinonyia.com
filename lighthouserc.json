{
  "ci": {
    "collect": {
      "staticDistDir": "./dist/client",
      "url": [
        "http://localhost/",
        "http://localhost/work/",
        "http://localhost/work/movement-fingerprint/",
        "http://localhost/writing/",
        "http://localhost/about/",
        "http://localhost/contact/"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "_comment": "Patterns must be NON-overlapping — each URL matches exactly one entry. Home page LCP is unmeasurable (page is sub-frame fast, Lighthouse never identifies an LCP candidate, perf score comes back null), so skip perf on / only.",
          "matchingUrlPattern": "localhost(:\\d+)?/$",
          "assertions": {
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.95 }],
            "categories:seo": ["error", { "minScore": 0.95 }]
          }
        },
        {
          "matchingUrlPattern": "localhost(:\\d+)?/.+/$",
          "assertions": {
            "categories:performance": ["error", { "minScore": 0.95 }],
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.95 }],
            "categories:seo": ["error", { "minScore": 0.95 }]
          }
        }
      ]
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
